# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=dehf
POSTGRES_USER=dehf
POSTGRES_PASSWORD=dehf
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── MinIO (S3-compatible object store) ────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed
# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
# ── YouTube Data API v3 ────────────────────────────────────────────────────────
# Get your key at https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_API_KEY=put_your_youtube_key_here
YOUTUBE_TOPICS=python,data engineering,artificial intelligence
YOUTUBE_MAX_RESULTS=10
# ── NewsAPI ────────────────────────────────────────────────────────────────────
# Get your key at https://newsapi.org/register
NEWS_API_KEY=put_your_newsapi_key_here
NEWS_QUERY=data engineering OR airflow OR python
NEWS_PAGE_SIZE=50
# ── Demo mode ──────────────────────────────────────────────────────────────────
# Set to "true" to run the full pipeline without real API keys.
# Both extract scripts will generate synthetic sample data instead of calling
# the external APIs. Useful for local testing and CI environments.
DEMO_MODE=false